pipeline {
    agent any

    triggers {
        // every 5 minutes on Mondays
        cron('H/5 * * * 1')
    }

    stages {

        stage('Checkout') {
            steps {
                // Explicitly checkout the 'main' branch
                git branch: 'main', url: 'https://github.com/3th34-Byte/spring-petclinic.git'
            }
        }

        stage('Build') {
            steps {
                // Windows-compatible build
                bat './mvnw.cmd clean package -DskipTests'
            }
        }

        stage('Test & JaCoCo') {
            steps {
                bat './mvnw.cmd test jacoco:report'
            }
        }

        stage('Publish JaCoCo') {
            steps {
                jacoco()
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
        }
    }
}
